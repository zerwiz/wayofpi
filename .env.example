# Way of Pi - Instance Configuration
# Copy this file to .env and customize for your instance

# Instance Identification (each location gets its own ID)
INSTANCE_ID=home-001
# Options: home-001, office-001, site-001, etc.

# PIN for local/demo authentication (4-6 digits recommended)
PIN=1234

# Database file (SQLite, per-instance)
DB_FILE=.wayofpi/instance.db

# Server Port (default: 3333, use higher ports for multiple instances)
PORT=3333

# Optional: ngrok token for external access
# Get free token from https://ngrok.com
# NGROK_TOKEN=your_ngrok_token_here

# Optional: Server config
# NODE_ENV=development
# LOG_LEVEL=info
