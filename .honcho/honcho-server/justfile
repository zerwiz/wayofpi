    @bash "{{justfile_directory()}}/scripts/honcho-open-ui.sh" cloud-explore

honcho-open-docs-web:
    @bash "{{justfile_directory()}}/scripts/honcho-open-ui.sh" docs-web

honcho-open-cloud-billing:
