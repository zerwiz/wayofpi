#!/usr/bin/env bash
# Run `pi` with this playground's .env loaded (OpenRouter, Ollama overrides, etc.).
# Usage: ./scripts/pi-with-env [pi-args…]
# Optional: alias pi='~/.pi/scripts/pi-with-env' if you want `pi` to always use this repo's keys.
set -euo pipefail
_script="${BASH_SOURCE[0]}"
while [[ -L "$_script" ]]; do
	_dir="$(cd -P "$(dirname "$_script")" && pwd)"
	_script="$(readlink "$_script")"
	[[ "$_script" == /* ]] || _script="$_dir/$_script"
done
SCRIPT_DIR="$(cd -P "$(dirname "$_script")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
export PI_PLAYGROUND="$ROOT"
if [[ -f "$ROOT/.env" ]]; then
	set -a
	# shellcheck source=/dev/null
	source "$ROOT/.env"
	set +a
fi
exec pi "$@"
