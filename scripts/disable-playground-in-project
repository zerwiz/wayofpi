#!/usr/bin/env bash
# Opt-out: remove playground settings files from a project.
#
# Usage:
#   ~/.pi/scripts/disable-playground-in-project [/abs/path/to/project]
#
set -euo pipefail

if ! command -v rg >/dev/null 2>&1; then
  echo "disable-playground-in-project: requires 'rg' (ripgrep) on PATH" >&2
  exit 127
fi

TARGET="${1:-$PWD}"
if [[ ! -d "$TARGET" ]]; then
  echo "disable-playground-in-project: target is not a directory: $TARGET" >&2
  exit 2
fi

rm -f "$TARGET/.pi/settings.playground.json"
echo "Removed: $TARGET/.pi/settings.playground.json (if it existed)"

# Only remove settings.json if it looks like it was generated by the enable script.
if [[ -f "$TARGET/.pi/settings.json" ]] && rg -q "/home/zerwiz/\\.pi/\\.pi/extensions/agent-team\\.ts" "$TARGET/.pi/settings.json"; then
  rm -f "$TARGET/.pi/settings.json"
  echo "Removed: $TARGET/.pi/settings.json"
else
  echo "Left:    $TARGET/.pi/settings.json (not the playground-generated file or already customized)"
fi

