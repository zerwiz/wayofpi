#!/usr/bin/env bash
# Opt-out: remove playground settings files from a project.
#
# Usage:
#   ~/.pi/scripts/disable-playground-in-project [/abs/path/to/project]
#
set -euo pipefail

TARGET="${1:-$PWD}"
if [[ ! -d "$TARGET" ]]; then
	echo "disable-playground-in-project: target is not a directory: $TARGET" >&2
	exit 2
fi

MARKER="$TARGET/.pi/.playground-from"
OUT="$TARGET/.pi/settings.json"

rm -f "$TARGET/.pi/settings.playground.json"
echo "Removed: $TARGET/.pi/settings.playground.json (if it existed)"

remove_pg_symlink() {
	local path="$1"
	local pg="$2"
	[[ -L "$path" ]] || return 0
	local r
	r="$(readlink -f "$path" 2>/dev/null || true)"
	[[ -n "$r" ]] || return 0
	case "$r" in
	"$pg" | "$pg"/*)
		rm -f "$path"
		echo "Removed symlink: $path"
		;;
	esac
}

if [[ -f "$MARKER" ]]; then
	PG="$(head -1 "$MARKER" | tr -d '\r')"
	rm -f "$MARKER"
	echo "Removed: $MARKER"
	if [[ -n "$PG" ]]; then
		remove_pg_symlink "$TARGET/.pi/agents" "$PG"
		remove_pg_symlink "$TARGET/.claude/commands" "$PG"
		remove_pg_symlink "$TARGET/.pi/damage-control-rules.yaml" "$PG"
	fi
	if [[ -f "$OUT" ]]; then
		rm -f "$OUT"
		echo "Removed: $OUT (playground opt-in)"
	fi
	exit 0
fi

# Legacy: enable script before marker files used absolute .../.pi/.pi/extensions/agent-team.ts
if [[ -f "$OUT" ]] && command -v rg >/dev/null 2>&1 && rg -q '\.pi/\.pi/extensions/agent-team\.ts' "$OUT"; then
	rm -f "$OUT"
	echo "Removed: $OUT (legacy playground-generated layout detected)"
else
	if [[ -f "$OUT" ]]; then
		echo "Left:    $OUT (no $MARKER — not removing unless you delete it manually)"
	fi
fi
