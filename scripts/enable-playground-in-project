#!/usr/bin/env bash
# Opt-in: use this Pi playground's extensions/skills/prompts/themes in another project.
#
# Default: <project>/.pi/settings.json gets every playground extension entry point
# (settings list + all shims + extension factories without shims), skills/themes, and
# optional symlinks. Set PLAYGROUND_LINK_LEAN=1 to only absolutize the paths already
# listed in playground .pi/settings.json (no auto-added factories) — lighter sessions.
#
# Safe behavior:
# - If <project>/.pi/settings.json already exists, we do NOT overwrite it.
#   We instead write <project>/.pi/settings.playground.json for manual merge.
# - When we write settings.json, we also write <project>/.pi/.playground-from
#   (one line: playground root) so disable-playground-in-project can remove safely.
#
# Usage:
#   ~/.pi/scripts/enable-playground-in-project [/abs/path/to/project]
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLAYGROUND="$(cd "$SCRIPT_DIR/.." && pwd)"
TARGET="${1:-$PWD}"
RENDER="$SCRIPT_DIR/render-playground-project-settings.py"

if ! command -v pi >/dev/null 2>&1; then
  echo "enable-playground-in-project: warning: 'pi' not on PATH (continuing — JSON only)" >&2
fi

if [[ ! -d "$TARGET" ]]; then
  echo "enable-playground-in-project: target is not a directory: $TARGET" >&2
  exit 2
fi

if ! command -v python3 >/dev/null 2>&1; then
  echo "enable-playground-in-project: requires python3 on PATH" >&2
  exit 127
fi

if [[ ! -f "$RENDER" ]]; then
  echo "enable-playground-in-project: missing $RENDER" >&2
  exit 3
fi

mkdir -p "$TARGET/.pi"

OUT="$TARGET/.pi/settings.json"
ALT="$TARGET/.pi/settings.playground.json"
MARKER="$TARGET/.pi/.playground-from"

# shellcheck source=/dev/null
source "$SCRIPT_DIR/link-playground-agent-trees.sh"

write_payload() {
  if [[ "${PLAYGROUND_LINK_LEAN:-0}" == "1" ]]; then
    python3 "$RENDER" "$PLAYGROUND" --lean
  else
    python3 "$RENDER" "$PLAYGROUND"
  fi
}

if [[ -f "$OUT" ]]; then
  write_payload > "$ALT"
  echo "Wrote: $ALT"
  echo "Note: $OUT already exists; merge manually if desired."
  exit 0
fi

write_payload > "$OUT"
echo "$PLAYGROUND" > "$MARKER"
echo "Wrote: $OUT"
echo "Wrote: $MARKER (marker for disable-playground-in-project)"
link_playground_agent_trees "$PLAYGROUND" "$TARGET"
