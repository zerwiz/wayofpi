#!/usr/bin/env bash
# Pi "standard" / vanilla harness — no project extension, skill, theme, or prompt-template
# discovery from settings.json (still uses ~/.pi/agent models, keys, AGENTS.md, etc.).
#
# Upstream docs: packages/coding-agent README → "CLI Reference" → Resource Options:
#   --no-extensions --no-skills --no-themes --no-prompt-templates
# https://github.com/badlogic/pi-mono/blob/main/packages/coding-agent/README.md
#
# Usage:
#   ./scripts/pi-standard [pi-args…]
#   pi-standard .          # leading "." is ignored (optional habit for "this directory")
#
set -euo pipefail
_script="${BASH_SOURCE[0]}"
while [[ -L "$_script" ]]; do
	_dir="$(cd -P "$(dirname "$_script")" && pwd)"
	_script="$(readlink "$_script")"
	[[ "$_script" == /* ]] || _script="$_dir/$_script"
done
SCRIPT_DIR="$(cd -P "$(dirname "$_script")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
export PI_PLAYGROUND="$ROOT"
export PI_CODING_AGENT_DIR="$ROOT/.pi/agent"

if [[ -f "$ROOT/.env" ]]; then
	set -a
	# shellcheck source=/dev/null
	source "$ROOT/.env"
	set +a
fi

if [[ "${1:-}" == "." ]]; then
	shift
fi

exec "$ROOT/node_modules/.bin/pi" --no-extensions --no-skills --no-themes --no-prompt-templates "$@"
