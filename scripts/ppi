#!/usr/bin/env bash
# Pi playground launcher: runs `just` from this repo so recipes work from any cwd.
# Install: ./scripts/install-ppi-global.sh   (or symlink only this file as ~/.local/bin/ppi)
#
#   ppi                    → just --list
#   ppi pi-e               → interactive extension picker
#   ppi ext-agent-team     → launch Pi with that stack
#
# When invoked via symlink ppi-<recipe> or pi-e, the recipe name is taken from the basename.
set -euo pipefail

# Resolve real path: symlinks from ~/.local/bin/pi-e → …/scripts/ppi must not use ~/.local/bin as SCRIPT_DIR
_script="${BASH_SOURCE[0]}"
while [[ -L "$_script" ]]; do
	_dir="$(cd -P "$(dirname "$_script")" && pwd)"
	_script="$(readlink "$_script")"
	[[ "$_script" == /* ]] || _script="$_dir/$_script"
done
SCRIPT_DIR="$(cd -P "$(dirname "$_script")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
export PI_PLAYGROUND="$ROOT"
# Directory the user was in before ppi `cd` (e.g. app repo). Used by `just pi-e` options 1–2
# and by `workspace-boundary` so the model knows the app vs the playground clone.
export PI_E_PROJECT_DIR="${PI_E_PROJECT_DIR:-$PWD}"
export PI_USER_PROJECT_DIR="${PI_USER_PROJECT_DIR:-$PI_E_PROJECT_DIR}"
cd "$ROOT"

# Load repo .env into the environment (API keys, Ollama, etc.) before just/pi.
# Keeps secrets out of committed JSON; pairs with agent/models.json OPENROUTER_API_KEY.
if [[ -f "$ROOT/.env" ]]; then
	set -a
	# shellcheck source=/dev/null
	source "$ROOT/.env"
	set +a
fi

if ! command -v just >/dev/null 2>&1; then
	echo "ppi: 'just' is not on PATH (install: https://github.com/casey/just )" >&2
	exit 127
fi

cmd="$(basename "$0")"

run_just() {
	exec just "$@"
}

# If Pi exits uncleanly after pi-e cleared extensions[] or shadowed ./tools, recovery files may remain.
# Uses PI_E_PROJECT_DIR (cwd captured before ppi switches to the playground repo).
pi_e_recover_project_if_stale() {
	local project_dir pi_dir bak tdir did=0
	project_dir="$(cd "${PI_E_PROJECT_DIR:-$PWD}" && pwd)"
	pi_dir="$project_dir/.pi"
	bak="$pi_dir/.settings.json.pi-e-restore"

	if [[ -f "$bak" ]]; then
		mkdir -p "$pi_dir"
		mv -f "$bak" "$pi_dir/settings.json"
		echo "pi-e: restored $pi_dir/settings.json from interrupted-session backup." >&2
		did=1
	fi

	tdir="$project_dir/tools"
	local stashes=()
	shopt -s nullglob
	stashes=( "$pi_dir"/.pi-tools-shadow.* )
	shopt -u nullglob
	if [[ ! -e "$tdir" && ${#stashes[@]} -eq 1 ]]; then
		mv "${stashes[0]}" "$tdir"
		echo "pi-e: restored ./tools from Pi session shadow (exit trap did not run)." >&2
		did=1
	elif [[ ! -e "$tdir" && ${#stashes[@]} -gt 1 ]]; then
		echo "pi-e: warning — multiple $pi_dir/.pi-tools-shadow.* entries; fix ./tools manually." >&2
	fi

	if [[ "$did" -eq 0 ]]; then
		echo "pi-e: no stale settings backup or tools shadow under $project_dir — opening picker." >&2
	fi
}

pi_e_print_help() {
	cat <<'EOF' >&2
pi-e
    Interactive extension picker (run from your app repo so PI_E_PROJECT_DIR is set correctly).

pi-e backup
pi-e restore
    If Pi crashed or was killed after pi-e started a session, recover:
      • .pi/settings.json from .pi/.settings.json.pi-e-restore
      • ./tools from .pi/.pi-tools-shadow.* when ./tools is missing (single stash only)
    Then opens the picker. After a normal Pi exit this runs automatically — use this when it did not.

    Do not use while Pi is still running for the same project.

pi-e help
    This message.
EOF
}

# First arg after `pi-e` / `ppi pi-e`.
pi_e_dispatch_cli() {
	case "${1:-}" in
	backup|restore)
		shift
		pi_e_recover_project_if_stale
		run_just pi-e "$@"
		;;
	help|-h|--help)
		pi_e_print_help
		exit 0
		;;
	esac
	run_just pi-e "$@"
}

if [[ "$cmd" == "ppi" ]]; then
	if [[ $# -eq 0 ]]; then
		run_just --list
	fi
	if [[ "$1" == "pi-e" ]]; then
		shift
		pi_e_dispatch_cli "$@"
	fi
	run_just "$@"
fi

if [[ "$cmd" == "pi-e" ]]; then
	pi_e_dispatch_cli "$@"
fi

if [[ "$cmd" == ppi-* ]]; then
	run_just "${cmd#ppi-}" "$@"
fi

echo "ppi: unexpected invocation name '$cmd'" >&2
exit 1
