{
  "sessions": {
    "autoSave": true,
    "storagePath": ".pi/storage/sessions",
    "fileFormat": "json",
    "maxFileSize": 10000,
    "compression": false,
    "dateFormat": "ISO",
    "includeMetadata": true,
    "pruneOlderThan": "30d",
    "notificationOnSave": true,
    "logLevel": "info"
  }
}
