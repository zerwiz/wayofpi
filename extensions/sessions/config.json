{
  "id": "session-saver",
  "name": "Session Saver",
  "description": "Automatically saves chat sessions to files after each user/assistant input",
  "version": "1.0.0",
  "main": "extensions/sessions/index.ts",
  "exports": {
    "./config": "./config.json"
  },
  "settings": {
    "autoSave": true,
    "storagePath": ".pi/storage/sessions",
    "includeMetadata": true,
    "notificationOnSave": true
  },
  "commands": [
    {
      "name": "save",
      "description": "Manually save current session branch",
      "shortcut": "/save"
    },
    {
      "name": "list",
      "description": "List all saved sessions",
      "shortcut": "/list"
    },
    {
      "name": "load",
      "description": "Load a saved message",
      "shortcut": "/load <filename>"
    },
    {
      "name": "show",
      "description": "Show a saved message in TUI viewer",
      "shortcut": "/show <filename>"
    }
  ],
  "enabled": true,
  "author": "Pi Extension Playground"
}
