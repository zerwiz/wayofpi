# ─────────────────────────────────────────────
#  Pi Agent — Provider API Keys Sample
#  Copy to .env and fill in your keys
#  Usage: source .env && pi
# ─────────────────────────────────────────────

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
GEMINI_API_KEY=AIza...

# OpenRouter (required for OpenRouter models; merges with Pi built-in catalog — see agent/models.json)
OPENROUTER_API_KEY=sk-or-...

# Firecrawl (used by pi-pi expert agents for web crawling)
FIRECRAWL_API_KEY=fc-...

# Brave Search API — optional; web_search provider (see WEB_TOOLS_SEARCH_ORDER)
# BRAVE_SEARCH_API_KEY=BSA...

# Web tools (extensions/web-tools.ts) — optional overrides
# Default search order: gemini,brave,duckduckgo (skip providers without keys)
# WEB_TOOLS_SEARCH_ORDER=gemini,brave,duckduckgo
# Gemini model for Google Search grounding + URL context (must support tools per Google docs)
# WEB_TOOLS_GEMINI_MODEL=gemini-2.0-flash
# web_fetch: http | gemini | fallback (HTTP then Gemini if weak/fail; needs GEMINI_API_KEY)
# WEB_TOOLS_FETCH_BACKEND=http

# Local Ollama (optional — default is http://localhost:11434; see agent/models.json)
# OLLAMA_HOST=http://127.0.0.1:11434
