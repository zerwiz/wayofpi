{
  "name": "wayofpi-technical",
  "productName": "Way of Pi — Technical IDE",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,ui -c blue,green \"bun run server/index.ts\" \"vite\"",
    "dev:ui": "vite",
    "dev:server": "bun run server/index.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production bun run server/index.ts"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.74.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "clsx": "^2.1.1",
    "diff": "^7.0.0",
    "dompurify": "^3.2.4",
    "highlight.js": "^11.11.1",
    "jose": "^6.2.3",
    "lucide-react": "^0.468.0",
    "marked": "^15.0.7",
    "mermaid": "^11.14.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/diff": "^7.0.2",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "~5.7.2",
    "vite": "^6.0.3"
  }
}
