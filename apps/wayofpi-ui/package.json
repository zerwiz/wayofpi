{
  "name": "wayofpi-ui",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "electron/electron-main.mjs",
  "desktopName": "wayofpi.desktop",
  "scripts": {
    "dev": "concurrently -k -n server,ui -c blue,green \"cross-env NODE_ENV=development bun run server/index.ts\" \"vite\"",
    "dev:ui": "vite",
    "dev:server": "cross-env NODE_ENV=development bun run server/index.ts",
    "electron:only": "cross-env ELECTRON_DEV=1 electron .",
    "electron:dev": "concurrently -k -n server,ui,electron -c blue,green,magenta \"cross-env NODE_ENV=development bun run server/index.ts\" \"vite\" \"wait-on http://127.0.0.1:5173 && cross-env ELECTRON_DEV=1 electron .\"",
    "electron:prod": "npm run build && concurrently -k -n server,electron -c blue,magenta \"bun run start\" \"node electron/wait-prod.mjs\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production bun run server/index.ts"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "diff": "^7.0.0",
    "dompurify": "^3.2.4",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.468.0",
    "marked": "^15.0.7",
    "mermaid": "^11.14.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "~5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  }
}
