{
  "name": "wayofpi-ui",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,ui -c blue,green \"bun run server/index.ts\" \"vite\"",
    "dev:ui": "vite",
    "dev:server": "bun run server/index.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production bun run server/index.ts"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "diff": "^8.0.4",
    "dompurify": "^3.3.3",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.468.0",
    "marked": "^18.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "~5.7.2",
    "vite": "^6.0.3"
  }
}
