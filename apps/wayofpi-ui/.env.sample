# Workspace the server may read/write (defaults to current working directory if unset)
WOP_WORKSPACE=/absolute/path/to/your/project

# API + WebSocket port
WOP_SERVER_PORT=3333

# When 1, Settings → Restart server… may POST /api/server/restart to exit this Bun process (dev only; restart npm run dev yourself).
# WOP_ALLOW_SERVER_RESTART=1

# LLM: ollama (default) or openrouter
WOP_LLM_PROVIDER=ollama

# Reserved: when set to `pi`, signals intent for headless Pi to own chat (Phase 2 — not wired yet; chat still uses WOP_LLM_PROVIDER).
# WOP_CHAT_ENGINE=pi


# Ollama (OpenAI-compatible). Same repo `.env` as Pi: **`OLLAMA_BASE_URL`** is accepted too (e.g. http://localhost:11434); **`OLLAMA_HOST`** wins if both are set.
OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_BASE_URL=http://localhost:11434
# Default model: **`OLLAMA_MODEL`** overrides **`agent/settings.json`** `defaultModel` when unset (Pi-style).
OLLAMA_MODEL=llama3

# OpenRouter (set WOP_LLM_PROVIDER=openrouter)
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=openrouter/auto

# Optional system prompt injected on each WebSocket session
# WOP_SYSTEM_PROMPT=You are a helpful coding assistant.

# Real interactive terminal (WebSocket /ws/terminal). Host shell, cwd = workspace — trusted machines only.
# Dev server defaults this ON when unset (and `npm run dev` forces NODE_ENV=development for Bun so inherited production does not skip that default). Set to 0, false, no, or off to disable. Production: use 1 / true / yes / on to enable the host PTY.
WOP_ALLOW_TERMINAL=1

# Optional: override default shell (Unix). Default is /bin/bash; on Windows cmd.exe is used.
# WOP_SHELL=/bin/zsh
