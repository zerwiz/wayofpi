# Worker Portal Environment Template
# Copy and modify for deployment

# Application Name
APP_NAME=worker-portal

# Base URL for the portal (used for redirects back to main app)
BASE_URL=http://localhost:5173

# Authentication (Simple token for demo, replace with real auth later)
PORTAL_TOKEN=worker-portal-token-secret

# Redirect URL after portal actions (main app URL)
PORTAL_REDIRECT_URL=http://localhost:5173
