.pi/agent-sessions/**/*.json
.pi/agent/models.json

# Other API key files
.pi/agent/auth.json
.deps/**/*.json
.cache/**/auth.json

.pi/agent-sessions/

# Local Pi agent state (machine-specific; do not publish chat logs)
agent/sessions/
apps/wayofwork-ui/agent/sessions/
agent/run-history.jsonl
agent/bin/
storage/sessions/

# Session saver + Chronicle local state (may contain chat / workflow data)
.pi/storage/sessions/
.pi/chronicle/ledger.json

.playwright-cli/

tmp/

# Way of Pi upstream sync (extract + optional mirror)
.tmp-wop-upstream/
vendor/wop-upstream/

# Local / vendored reference dumps (import scripts may use a path outside the repo)
ref/

# Machine-local playground link marker — never commit (belongs under `<project>/.pi/` when linked)
/.playground-from

# Session files (machine-specific runtime state)
.pi/agent-sessions/*.json
apps/wayofpi-ui/agent/sessions/*.json
storage/sessions/*.json

# Local agent state files
agent/sessions/
agent/bin/
storage/

# Chronicle session ledger
.pi/chronicle/
.pi/storage/sessions/
chronicle/

# Pi UI state under repo root (not `.pi/storage/`)
storage/

# Chronicle ledger at repo root (session metadata)
chronicle/

# Way of Pi — GitHub PAT written under an opened workspace (do not publish)
.wayofpi/github-credentials.json

# Release artifacts (large build files)
release/

# Startup diagnostics logs (machine-specific runtime state)
logs/
