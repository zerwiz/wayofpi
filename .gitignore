*.pyc
.DS_Store
*.swp
*.swo

# API keys — never commit real credentials
.env
agent/auth.json
.pi/agent/models.json

# ngrok dashboard authtoken — local one-line file only (never commit)
apps/wayofwork-ui/.ngrok-authtoken.local

